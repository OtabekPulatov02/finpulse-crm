# Telegram
TELEGRAM_BOT_TOKEN=

# Secret Telegram sends back in the "X-Telegram-Bot-Api-Secret-Token" header
# on every webhook request, so /api/bot can verify a request actually came
# from Telegram (not a forged Update JSON posted by anyone who finds the URL).
# SECURITY: set this to a long random string (32+ chars) and keep it set.
# After changing it, re-run the setup endpoint (GET /api/bot?setup=<BIND_CODE>)
# or call bot.api.setWebhook again so Telegram starts sending the new secret.
TG_WEBHOOK_SECRET=

# Shared code used for two purposes:
#  - Telegram group command "/bind <code>" to link the accountants group.
#  - GET /api/bot?setup=<code> to (re)configure the bot's profile/webhook.
# SECURITY: set this to a long random string (32+ chars) — anyone who knows
# it can re-point the group the bot posts task cards into.
BIND_CODE=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- /api/crm access (temporary, until JWT session auth) ---
# Shared secret the CRM frontend must send in the "x-api-key" header.
# SECURITY: this app holds real client financial data — set a real value
# (32+ chars) in production. Leave empty only for local/throwaway testing.
CRM_API_KEY=

# Comma-separated list of allowed Origins for CORS on /api/crm.
# Example: https://finpulse-crm-app.vercel.app,https://app.yourdomain.com
# SECURITY: must be set in production — an empty list reflects any Origin
# back (effectively no CORS restriction).
CRM_ALLOWED_ORIGINS=

# --- Auth (client/employee login, roles) ---
# Secret used to sign/verify session JWTs (api/auth.js, api/crm.js).
# Once this is set, /api/crm and /api/auth start enforcing roles.
# SECURITY: use a long random value (32+ chars) — a short/guessable
# secret makes token forgery via brute force feasible.
JWT_SECRET=

# One-time bootstrap secret to create the first super-admin employee
# via POST /api/auth {action:"bootstrap_admin", login, password, name}
# with header x-bootstrap-secret. Only works while no employees exist yet.
# SECURITY: use a long random value (20+ chars); rotate/remove after first use.
BOOTSTRAP_ADMIN_SECRET=

# Public URL of the CRM frontend, used in the Telegram message that
# gives clients their CRM login/password.
CRM_APP_URL=https://finpulse-crm-app.vercel.app

# --- Vercel Cron (reminder calendar) ---
# Secret Vercel Cron sends as "Authorization: Bearer <CRON_SECRET>".
# SECURITY: set this in production — leaving it empty leaves the cron
# endpoint callable by anyone who finds the URL.
CRON_SECRET=

# --- Daily Redis backup (api/cron/backup.js) ---
# Fine-grained GitHub PAT, scoped ONLY to the backup repo below, with
# "Contents: Read and write" permission. Create a small PRIVATE repo
# just for backups (e.g. finpulse-crm-backups) — don't reuse the app
# repo, keep product code and data snapshots separate.
GITHUB_BACKUP_TOKEN=
GITHUB_BACKUP_REPO=OtabekPulatov02/finpulse-crm-backups

# --- Health monitor (api/ops.js ?r=health, called by external cron) ---
# Vercel Hobby crons only run once/day, so 5-minute health checks are
# driven by a GitHub Actions workflow (see .github/workflows) using the
# same CRON_SECRET above as its bearer token.
