# Telegram
TELEGRAM_BOT_TOKEN=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- /api/crm access (temporary, until JWT session auth) ---
# Shared secret the CRM frontend must send in the "x-api-key" header.
# Leave empty during transition to avoid breaking the frontend before it's wired up.
CRM_API_KEY=

# Comma-separated list of allowed Origins for CORS on /api/crm.
# Example: https://finpulse-crm-app.vercel.app,https://app.yourdomain.com
CRM_ALLOWED_ORIGINS=

# --- Auth (client/employee login, roles) ---
# Secret used to sign/verify session JWTs (api/auth.js, api/crm.js).
# Once this is set, /api/crm and /api/auth start enforcing roles.
JWT_SECRET=

# One-time bootstrap secret to create the first super-admin employee
# via POST /api/auth {action:"bootstrap_admin", login, password, name}
# with header x-bootstrap-secret. Only works while no employees exist yet.
BOOTSTRAP_ADMIN_SECRET=

# Public URL of the CRM frontend, used in the Telegram message that
# gives clients their CRM login/password.
CRM_APP_URL=https://finpulse-crm-app.vercel.app

# --- Vercel Cron (reminder calendar) ---
# Secret Vercel Cron sends as "Authorization: Bearer <CRON_SECRET>".
# Leave empty to leave the cron endpoint open during initial rollout.
CRON_SECRET=

